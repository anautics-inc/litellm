# syntax=docker/dockerfile:1
# Containerfile.sbom for generating build/runtime CycloneDX SBOMs.

ARG LITELLM_BUILD_IMAGE=cgr.dev/chainguard/wolfi-base@sha256:31da6565f35af6401031c1d7aa91dc84ac76c5c48edd17fb90f0ed9e3173c7a9
ARG UV_IMAGE=ghcr.io/astral-sh/uv:0.11.7@sha256:240fb85ab0f263ef12f492d8476aa3a2e4e1e333f7d67fbdd923d00a506a516a

FROM ${UV_IMAGE} AS uvbin

FROM ${LITELLM_BUILD_IMAGE} AS build-sbom

WORKDIR /app
USER root

COPY --from=uvbin /uv /usr/local/bin/uv
COPY --from=uvbin /uvx /usr/local/bin/uvx

RUN apk add --no-cache \
    bash \
    gcc \
    python3 \
    python3-dev \
    py3-pip \
    openssl \
    openssl-dev

ENV UV_PROJECT_ENVIRONMENT=/app/.venv \
    UV_LINK_MODE=copy \
    PATH="/app/.venv/bin:${PATH}"

COPY pyproject.toml uv.lock ./
COPY enterprise/pyproject.toml enterprise/
COPY litellm-proxy-extras/pyproject.toml litellm-proxy-extras/

# Install all third-party dependencies first to maximize layer cache reuse.
RUN uv sync --frozen --no-install-project --no-install-workspace --all-extras --all-groups --python python3

COPY . .

# Install workspace packages to include project-local components in the SBOM.
RUN uv sync --frozen --all-extras --all-groups --python python3

RUN pip install --no-cache-dir cyclonedx-bom==7.2.1

RUN mkdir -p /out && \
    cyclonedx-py environment /app/.venv/bin/python --output-format JSON -o /out/build-sbom.json

FROM ${LITELLM_BUILD_IMAGE} AS runtime-sbom

WORKDIR /app
USER root

COPY --from=uvbin /uv /usr/local/bin/uv
COPY --from=uvbin /uvx /usr/local/bin/uvx

RUN apk add --no-cache \
    bash \
    gcc \
    python3 \
    python3-dev \
    py3-pip \
    openssl \
    openssl-dev

ENV UV_PROJECT_ENVIRONMENT=/app/.venv \
    UV_LINK_MODE=copy \
    PATH="/app/.venv/bin:${PATH}"

COPY pyproject.toml uv.lock ./
COPY enterprise/pyproject.toml enterprise/
COPY litellm-proxy-extras/pyproject.toml litellm-proxy-extras/

RUN uv sync --frozen --no-install-project --no-install-workspace --no-default-groups --no-editable \
    --extra proxy \
    --extra proxy-runtime \
    --extra extra_proxy \
    --extra semantic-router \
    --python python3

COPY . .

RUN uv sync --frozen --no-default-groups --no-editable \
    --extra proxy \
    --extra proxy-runtime \
    --extra extra_proxy \
    --extra semantic-router \
    --python python3

RUN pip install --no-cache-dir cyclonedx-bom==7.2.1

RUN mkdir -p /out && \
    cyclonedx-py environment /app/.venv/bin/python --output-format JSON -o /out/runtime-sbom.json

FROM ${LITELLM_BUILD_IMAGE} AS sbom-output

WORKDIR /sbom
COPY --from=build-sbom /out/build-sbom.json ./build-sbom.json
COPY --from=runtime-sbom /out/runtime-sbom.json ./runtime-sbom.json
